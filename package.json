{
  "name": "virtual-ta-ide",
  "displayName": "Virtual TA",
  "description": "Your AI-powered Virtual Technical Assistant embedded natively directly into the IDE",
  "version": "0.1.0",
  "publisher": "gca-americas",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Education"
  ],
  "activationEvents": [
    "onView:virtual-ta-sidebar"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "virtual-ta",
          "title": "Virtual TA",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "virtual-ta": [
        {
          "type": "webview",
          "id": "virtual-ta-sidebar",
          "name": "Chat Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "virtual-ta.sendErrorToTA",
        "title": "Send Error to Virtual TA"
      }
    ],
    "menus": {
      "terminal/context": [
        {
          "command": "virtual-ta.sendErrorToTA",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}